# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=frame_note
DB_USER=postgres
DB_PASSWORD=postgres

# Server Configuration
PORT=3000
NODE_ENV=development

# Google Gemini AI (Required for Visual Suggestions feature)
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Google Drive integration (Required for loading videos from Google Drive)
# Create an OAuth 2.0 "Web application" client at https://console.cloud.google.com/apis/credentials
# Enable the Google Drive API, and add the redirect URI below to the client's authorized redirect URIs.
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/drive/callback
# Origin of the frontend (used as the postMessage target after OAuth and to close the popup)
FRONTEND_ORIGIN=http://localhost:5173

# Directus CMS (Required for uploading comment image/file attachments)
# The backend proxies uploads to Directus so the token stays server-side.
# DIRECTUS_URL: base URL of your Directus instance (no trailing slash)
# DIRECTUS_TOKEN: a static access token with permission to create files
# DIRECTUS_UPLOAD_FOLDER: the id (UUID) of the folder attachments should land in
# The target folder/files must be public-read so <img src> can load the asset URL.
DIRECTUS_URL=https://your-directus-instance.example.com
DIRECTUS_TOKEN=your-directus-static-token
DIRECTUS_UPLOAD_FOLDER=your-directus-folder-id

